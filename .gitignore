# ──────────────────────────────────────────────────────────────
# Dependencies
# ──────────────────────────────────────────────────────────────
node_modules/
**/node_modules/

# ──────────────────────────────────────────────────────────────
# Environment & secrets (NEVER commit these)
# ──────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
**/.env
!**/.env.example

# ──────────────────────────────────────────────────────────────
# Logs & debug
# ──────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/

# ──────────────────────────────────────────────────────────────
# Build outputs
# ──────────────────────────────────────────────────────────────
dist/
build/
out/
out-tsc/
.angular/
coverage/

# ──────────────────────────────────────────────────────────────
# Databases / local data
# ──────────────────────────────────────────────────────────────
*.sqlite
*.sqlite3
*.db
backend/data/

# ──────────────────────────────────────────────────────────────
# AI orchestrator run artifacts (LLM responses, generated plans)
# Keep the folder present but ignore generated contents.
# ──────────────────────────────────────────────────────────────
ai-orchestrator/outputs/*
!ai-orchestrator/outputs/.gitkeep

# ──────────────────────────────────────────────────────────────
# OS
# ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini

# ──────────────────────────────────────────────────────────────
# Editors / IDEs
# ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ──────────────────────────────────────────────────────────────
# Claude Code — keep shared settings, ignore personal ones
# ──────────────────────────────────────────────────────────────
.claude/settings.local.json

# ──────────────────────────────────────────────────────────────
# Misc
# ──────────────────────────────────────────────────────────────
*.tgz
.cache/
tmp/
temp/
